# Copy to ops/.secrets.env and fill with ROTATED keys, then run:
#   ./ops/scripts/set-secrets.sh
#
# ops/.secrets.env is gitignored — never commit real values.
# The keys first pasted into chat are compromised; generate fresh ones.

# OpenAI — OPTIONAL here. Both ops services already reference the api service's
# key via ${{api.OPENAI_API_KEY}} (auto-tracks rotation). Leave this blank unless
# you want a dedicated ops key that overrides the reference.
OPENAI_API_KEY=

# Resend — transactional email (failure alerts + Job B digest). From denemlabs.com.
# REQUIRED — no other source exists.
RESEND_API_KEY=re_REPLACE_ME

# GitHub — fine-grained PAT scoped to the 4 commontrace repos:
#   contents:read, metadata:read, pull_requests:read, issues:write
# REQUIRED — no other source exists.
GITHUB_TOKEN=github_pat_REPLACE_ME
